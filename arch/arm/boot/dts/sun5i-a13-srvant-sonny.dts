/dts-v1/;
#include "sun5i-a13.dtsi"
#include "sunxi-common-regulators.dtsi"

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/interrupt-controller/irq.h>

/ {
	model = "Olimex A13-Olinuxino Micro";
	compatible = "olimex,a13-olinuxino-micro", "allwinner,sun5i-a13";

	aliases {
		serial0 = &uart1;
		serial3 = &uart3;

		i2c0 = "/soc@1c00000/i2c@1c2ac00";
		i2c1 = "/soc@1c00000/i2c@1c2b000";
		i2c2 = "/soc@1c00000/i2c@1c2b400";

        eth0 = &spi0;
	};

	chosen {
		stdout-path = "serial0:115200n8";
	};

	leds {
		compatible = "gpio-leds";
		pinctrl-names = "default";
		pinctrl-0 = <&led_pins_olinuxinom &leg_pins_srvant>;

		power {
			label = "a13-olinuxino-micro:blue:power";
			gpios = <&pio 2 4 GPIO_ACTIVE_HIGH>;
			linux,default-trigger = "heartbeat";
		};

		identify {
			label = "srvant:yellow:usr";
			gpios = <&pio 1 4 GPIO_ACTIVE_HIGH>;
			default-state = "on";
		};
	};
};

&ehci0 {
	status = "okay";
};

&i2c0 {
	status = "okay";
};

&i2c1 {
	status = "okay";
};

&i2c2 {
	status = "okay";
};

&mmc0 {
	vmmc-supply = <&reg_vcc3v3>;
	bus-width = <4>;
	cd-gpios = <&pio 6 0 GPIO_ACTIVE_LOW>; /* PG0 */
	status = "okay";
};

&ohci0 {
	status = "okay";
};

&otg_sram {
	status = "okay";
};

&pio {
	led_pins_olinuxinom: led-pin {
		pins = "PC4";
		function = "gpio_out";
		drive-strength = <20>;
	};
	leg_pins_srvant: led-pin {
		pins = "PB4";
		function = "gpio_out";
		drive-strength = <20>;
	};

	spi0_pc_pins: spi0-pc-pins {
		pins = "PC0", "PC1", "PC2";
		function = "spi0";
	};

	spi0_cs0_pc_pin: spi0-cs0-pc-pin {
		pins = "PC3";
		function = "spi0";
	};

};

&reg_usb0_vbus {
	gpio = <&pio 6 12 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

&reg_usb1_vbus {
	gpio = <&pio 6 11 GPIO_ACTIVE_HIGH>;
	status = "okay";
};

&uart1 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart1_pg_pins>;
	status = "okay";
};

&uart3 {
	pinctrl-names = "default";
	pinctrl-0 = <&uart3_pg_pins>;
	status = "okay";
};

&pwm {
	pinctrl-names = "default";
	pinctrl-0 = <&pwm0_pin>;
	status = "okay";
};

&spi0 {
    #address-cells = <1>;
    #size-cells = <0>;

    status = "okay";

    eth1: w5500@0{
        compatible = "wiznet,w5100";
        reg = <0>;
        pinctrl-names = "default";
        pinctrl-0 = <&spi0_pc_pins>, <&spi0_cs0_pc_pin>;
        interrupt-parent = <&pio>;
        interrupts = <25 0x8>;
        spi-max-frequency = <30000000>;
        local-mac-address = [ aa bb cc dd ee ff ];
        status = "okay";
    };
};


&usb_otg {
	dr_mode = "otg";
	status = "okay";
};

&usbphy {
	usb0_id_det-gpios = <&pio 6 2 (GPIO_ACTIVE_HIGH | GPIO_PULL_UP)>; /* PG2 */
	usb0_vbus_det-gpios = <&pio 6 1 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>; /* PG1 */
	usb0_vbus-supply = <&reg_usb0_vbus>;
	usb1_vbus-supply = <&reg_usb1_vbus>;
	status = "okay";
};
